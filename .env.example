# ============================================================
# Required for all services
# ============================================================
# Get these from https://my.telegram.org -> API development tools
API_ID=1234567
API_HASH=your_api_hash_here

# ============================================================
# Service toggles (1=on, 0=off). Defaults to on.
# ============================================================
ENABLE_FARMCLICKERS=1
ENABLE_NOTPIXEL=1
ENABLE_TOMARKETOD=1

# ============================================================
# NotPixel tuning (optional)
# ============================================================
NOTPIXEL_PAINT_REWARD_MAX=5        # max 7
NOTPIXEL_ENERGY_LIMIT_MAX=5        # max 6
NOTPIXEL_RE_CHARGE_SPEED_MAX=5     # max 11
NOTPIXEL_USE_PROXY=False
# NOTPIXEL_PROXY_HTTP=socks5://user:pass@host:port
# NOTPIXEL_PROXY_HTTPS=socks5://user:pass@host:port

# ============================================================
# Advanced (optional)
# ============================================================
# Override persistent volume mount path. Railway recommends /data.
# DATA_VOLUME=/data
